{
    "name": "lingo-bharat",
    "version": "1.0.0",
    "type": "module",
    "description": "Indic localization readiness checker for Lingo.dev projects",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "bin": {
        "lingo-bharat": "./dist/index.js"
    },
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "start": "node dist/index.js",
        "check": "node dist/index.js check",
        "fix": "node dist/index.js fix"
    },
    "keywords": [
        "i18n",
        "l10n",
        "india",
        "indic",
        "localization",
        "lingo.dev",
        "hindi",
        "tamil",
        "telugu",
        "bengali",
        "bharat",
        "quality-assurance"
    ],
    "dependencies": {
        "@lingo-bharat/core": "workspace:*",
        "chalk": "^5.4.0",
        "cli-table3": "^0.6.5",
        "commander": "^12.0.0",
        "lingo.dev": ">=0.130.0",
        "ora": "^8.0.0"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "typescript": "^5.7.0"
    }
}